DEBUG='True' # set to False or unset in production
# Uncomment the following four lines for production (SWAG/Let's Encrypt):
# NGINX_IMAGE='lscr.io/linuxserver/swag'
# NGINX_TAG='2.11.0'  # REQUIRED with a custom NGINX_IMAGE (update.sh enforces this): pin the swag
#                     # release the host already runs (docker inspect nginx | grep image.version);
#                     # version tags still get -ls rebuilds on pull. Dev default is nginx 1.27.
# NGINX_CONF='./nginx.prod.conf'
# NGINX_CONF_LOCATION='/config/nginx/site-confs/default.conf'

# MariaDB release series to run (security patches within the series arrive on pull).
# Leave unset to use the LTS default in docker-compose.yaml. If your existing database
# volume was created under a newer series, set that series here (check with
# docker exec db mariadb --version) -- MariaDB cannot downgrade a data directory.
# MARIADB_VERSION='11.4'

HTTP_PORT="80"
SSL_PORT="443"
LOG_LEVEL='WARNING'
DJANGO_LOG_LEVEL='WARNING'
SETUP_COMPLETE="0"

SITE_DOMAIN="127.0.0.1"
ADMIN_EMAIL='admin@example.com'
DEFAULT_FROM_EMAIL="Notifications <admin@example.com>"
NAVBAR_BRAND="My website"
COPYRIGHT_MESSAGE="Website copyright me"
# Show the site icon in the footer, just before COPYRIGHT_MESSAGE.
SHOW_FOOTER_ICON="True"
MAILING_ADDRESS="123 your street, Anytown, USA"
WEBSITE_FOCUS="stuff"

# One club per site (the default). The club is named after NAVBAR_BRAND above.
# Set to False only if you run multiple clubs on one install (like auction.fish).
SINGLE_CLUB_MODE="True"

POST_OFFICE_EMAIL_BACKEND="django.core.mail.backends.console.EmailBackend"
EMAIL_USE_TLS='True'
EMAIL_HOST='smtp.gmail.com'
EMAIL_PORT='587'
EMAIL_HOST_USER=''
EMAIL_HOST_PASSWORD=''
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_PROFILE="default"
AWS_SES_REGION_NAME="us-east-1"
AWS_SES_REGION_ENDPOINT="email.us-east-1.amazonaws.com"
AWS_SES_CONFIGURATION_SET=""
INBOUND_ROUTING_SECRET=""

GOOGLE_MEASUREMENT_ID=""
GOOGLE_TAG_ID=""
GOOGLE_ADSENSE_ID=""
SHOW_ADS="True"
GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_SERVER_API_KEY=""
GOOGLE_OAUTH_LINK=""
GOOGLE_OAUTH_CLIENT_ID=""
RECAPTCHA_PUBLIC_KEY=""
RECAPTCHA_PRIVATE_KEY=""

ALLOW_USERS_TO_CREATE_AUCTIONS="True"
ALLOW_USERS_TO_CREATE_LOTS="True"
ENABLE_PROMO_PAGE="False"
ENABLE_CLUB_FINDER="True"
ENABLE_HELP="False"
I_BRED_THIS_FISH_LABEL="I bred this fish/propagated this plant"
WEEKLY_PROMO_MESSAGE=""

# Mobile push notifications (Firebase Cloud Messaging). Leave all blank to disable push; every
# notification then falls back to email. FIREBASE_CREDENTIALS_JSON is the service-account key the
# server sends with (a secret) -- inline JSON or a path. The two config-file paths point at the
# public client files that ship with the mobile build (google-services.json / GoogleService-Info.plist);
# they let the app register for push and are served (public values only) from /api/mobile/config/.
# The client files are parsed at startup -- restart after changing them.
FIREBASE_CREDENTIALS_JSON=""
FIREBASE_ANDROID_CONFIG_FILE=""
FIREBASE_IOS_CONFIG_FILE=""

PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
PAYPAL_ENABLED_FOR_USERS="False"
PARTNER_MERCHANT_ID=""
PAYPAL_BN_CODE=""
PAYPAL_PLATFORM_FEE="0"
SQUARE_ENABLED_FOR_USERS="False"
USERS_ARE_TRUSTED_BY_DEFAULT="True"
UNTRUSTED_MESSAGE="You cannot currently promote auctions. Please contact the website administrator for access."

# Cloudflare Images: serve lot/club/ad images from Cloudflare's CDN instead of local files.
# Requires a Cloudflare account with the Images subscription. Set all three of account ID
# (dashboard home page), an API token with Cloudflare Images edit permission, and the
# account hash (Images > Overview > Developer Resources). Leave blank to keep serving
# images locally with easy-thumbnails.
# Once set: run `manage.py migrate_to_cloudflare_images --setup` once to create the image
# variants, then existing images move over automatically (one per minute via celery beat),
# or run `manage.py migrate_to_cloudflare_images --count 100000` to move everything at once.
CLOUDFLARE_IMAGES_ACCOUNT_ID=""
CLOUDFLARE_IMAGES_API_TOKEN=""
CLOUDFLARE_IMAGES_ACCOUNT_HASH=""
# Optional: serve images from your own domain (must be proxied through Cloudflare on the
# same account) instead of imagedelivery.net, e.g. "auction.example.com"
CLOUDFLARE_IMAGES_DOMAIN=""

GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_KEYFILE=""
APPLE_WALLET_CERT_FILE=""
APPLE_WALLET_CERT_PASSWORD=""
APPLE_WALLET_WWDR_FILE=""
APPLE_WALLET_PASS_TYPE_IDENTIFIER=""
APPLE_WALLET_TEAM_IDENTIFIER=""
APPLE_WALLET_ORGANIZATION_NAME=""

PUID=1000
PGID=1000
DISCORD_PUBLIC_KEY=""
DISCORD_BOT_TOKEN=""
DISCORD_BOT_CLIENT_ID=""
MAILCHIMP_CLIENT_ID=""
MAILCHIMP_CLIENT_SECRET=""
